# ~/.newsboat/config
# Newsboat config

#Color schemes
#The package ships with a number of schemes in
#/usr/share/doc/newsboat/contrib/colorschemes/ 
#include /usr/share/doc/newsboat/contrib/colorschemes/inkpot

refresh-on-startup yes

always-display-description no

display-article-progress yes

goto-first-unread yes

notify-beep no

notify-always yes

notify-screen no

#pager

#show-title-bar no

#show-read-articles no

#show-read-feeds no

#swap-title-and-hints yes

confirm-exit no

#cleanup-on-quit no

#delete-read-articles-on-quit no


#Automatic feed reloads
#{ /usr/bin/newsboat -x reload ;}
auto-reload no
#reload-time <desired number of minutes>

#Loading of feeds in parallel for faster updates
#reload-threads 100
reload-only-visible-feeds no


#Subheadings (hack)
highlight feedlist "---.*---" red default bold
highlight feedlist ".*0/0.." default default invis


#color info default default reverse
#color listnormal_unread yellow default
#color listfocus blue default reverse bold
#color listfocus_unread blue default reverse bold

#https://wiki.archlinux.org/index.php/Newsboat#Configuration
#https://github.com/gpakosz/.newsboat/blob/master/config
#

